{
    "name": "@personal/logseq-time-tracker",
    "version": "0.1.0",
    "description": "Time Tracker Logseq Plugin with Svelte 5",
    "main": "dist/index.html",
    "type": "module",
    "scripts": {
        "prebuild": "node scripts/copy_sql_wasm.mjs",
        "dev": "node scripts/copy_sql_wasm.mjs && vite",
        "dev:playwright": "vite --config e2e/vite.config.ts --port 5174",
        "build": "vite build",
        "type-check": "tsc --noEmit && svelte-check --tsconfig ./tsconfig.json",
        "lint": "eslint . --ext ts,svelte --report-unused-disable-directives --max-warnings 0",
        "format": "prettier --write \"src/**/*.{ts,svelte,json,css.ts}\"",
        "format:check": "prettier --check \"src/**/*.{ts,svelte,json,css.ts}\"",
        "test": "vitest run --passWithNoTests",
        "test:watch": "vitest",
        "test:e2e": "playwright test",
        "test:e2e:update-snapshots": "playwright test --update-snapshots"
    },
    "license": "MIT",
    "dependencies": {
        "@logseq/libs": "catalog:",
        "@personal/time-tracker-core": "workspace:*",
        "@vanilla-extract/css": "catalog:"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.11.1",
        "@eslint/js": "catalog:",
        "@playwright/test": "^1.58.2",
        "@sveltejs/vite-plugin-svelte": "catalog:",
        "@types/node": "catalog:",
        "@vanilla-extract/vite-plugin": "catalog:",
        "eslint": "catalog:",
        "eslint-plugin-svelte": "catalog:",
        "globals": "catalog:",
        "jsdom": "catalog:",
        "prettier": "catalog:",
        "sql.js": "^1.14.1",
        "svelte": "catalog:",
        "svelte-check": "catalog:",
        "typescript": "catalog:",
        "typescript-eslint": "catalog:",
        "vite": "catalog:",
        "vite-plugin-logseq": "catalog:",
        "vitest": "catalog:"
    },
    "peerDependencies": {
        "svelte": "catalog:"
    },
    "logseq": {
        "id": "logseq-time-tracker",
        "title": "Time Tracker",
        "icon": "./logo.svg",
        "main": "dist/index.html"
    }
}
