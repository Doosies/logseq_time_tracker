{
    "name": "@personal/ecount-dev-tool",
    "version": "1.0.0",
    "description": "ecount.com Development Environment Manager Chrome Extension",
    "type": "module",
    "imports": {
        "#services/*": "./src/services/*",
        "#components/*": "./src/components/*",
        "#stores/*": "./src/stores/*",
        "#constants/*": "./src/constants/*",
        "#types/*": "./src/types/*",
        "#utils/*": "./src/utils/*",
        "#sections": "./src/sections/index.ts",
        "#test/*": "./src/test/*"
    },
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "type-check": "tsc --noEmit && svelte-check --tsconfig ./tsconfig.json",
        "lint": "eslint . --ext ts,svelte --report-unused-disable-directives --max-warnings 0",
        "format": "prettier --write \"src/**/*.{ts,svelte,json,css.ts}\"",
        "format:check": "prettier --check \"src/**/*.{ts,svelte,json,css.ts}\"",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@codemirror/autocomplete": "^6.20.1",
        "@codemirror/commands": "^6.10.3",
        "@codemirror/lang-javascript": "^6.2.5",
        "@codemirror/language": "^6.12.2",
        "@codemirror/lint": "^6.9.5",
        "@codemirror/search": "^6.6.0",
        "@codemirror/state": "^6.6.0",
        "@codemirror/view": "^6.40.0",
        "@lezer/highlight": "^1.2.3",
        "@personal/uikit": "workspace:*"
    },
    "devDependencies": {
        "@eslint/js": "catalog:",
        "@sveltejs/vite-plugin-svelte": "catalog:",
        "@testing-library/dom": "catalog:",
        "@testing-library/jest-dom": "catalog:",
        "@testing-library/svelte": "catalog:",
        "@testing-library/user-event": "catalog:",
        "@types/chrome": "catalog:",
        "@vanilla-extract/vite-plugin": "catalog:",
        "@vitest/coverage-v8": "catalog:",
        "eslint": "catalog:",
        "eslint-plugin-svelte": "catalog:",
        "globals": "catalog:",
        "jsdom": "catalog:",
        "prettier": "catalog:",
        "svelte": "catalog:",
        "typescript": "catalog:",
        "typescript-eslint": "catalog:",
        "vite": "catalog:",
        "vite-plugin-web-extension": "catalog:",
        "vitest": "catalog:"
    }
}
